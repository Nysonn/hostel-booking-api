generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  admin
  university
  landlord
  student
}

enum Gender {
  male
  female
}

enum UniversityType {
  government
  private
}

enum RoomType {
  single_self_contained
  double_self_contained
}

enum BookingStatus {
  active
  terminated
}

enum PaymentType {
  partial
  full
}

enum PaymentMethod {
  mtn_mobile_money
  airtel_mobile_money
}

enum PaymentStatus {
  success
  failed
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id          String   @id @default(uuid())
  clerkId     String   @unique @map("clerk_id")
  role        UserRole
  isSuspended Boolean  @default(false) @map("is_suspended")
  firstLogin  Boolean  @default(true) @map("first_login")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  university    University?
  landlord      Landlord?
  student       Student?
  notifications Notification[]

  @@map("users")
}

model University {
  id             String         @id @default(uuid())
  userId         String         @unique @map("user_id")
  universityName String         @map("university_name")
  location       String
  type           UniversityType
  email          String         @unique
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id])
  landlords Landlord[]
  students  Student[]
  hostels   Hostel[]

  @@map("universities")
}

model Landlord {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  universityId       String   @map("university_id")
  fullName           String   @map("full_name")
  gender             Gender
  nin                String
  maritalStatus      String   @map("marital_status")
  landlordCode       String   @unique @map("landlord_code")
  whatsappNumber     String   @map("whatsapp_number")
  email              String   @unique
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  university University @relation(fields: [universityId], references: [id])
  hostels    Hostel[]

  @@map("landlords")
}

model Student {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  universityId       String   @map("university_id")
  registrationNumber String   @unique @map("registration_number")
  surname            String
  otherNames         String   @map("other_names")
  gender             Gender
  studentEmail       String   @unique @map("student_email")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  university University @relation(fields: [universityId], references: [id])
  bookings   Booking[]
  payments   Payment[]

  @@map("students")
}

model Hostel {
  id             String   @id @default(uuid())
  landlordId     String   @map("landlord_id")
  universityId   String   @map("university_id")
  hostelName     String   @map("hostel_name")
  location       String
  description    String
  images         String[]
  whatsappNumber String   @map("whatsapp_number")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  landlord   Landlord   @relation(fields: [landlordId], references: [id])
  university University @relation(fields: [universityId], references: [id])
  rooms      Room[]

  @@map("hostels")
}

model Room {
  id            String   @id @default(uuid())
  hostelId      String   @map("hostel_id")
  roomType      RoomType @map("room_type")
  price         Decimal  @db.Decimal(12, 2)
  capacity      Int
  occupiedSlots Int      @default(0) @map("occupied_slots")
  isAvailable   Boolean  @default(true) @map("is_available")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  hostel   Hostel    @relation(fields: [hostelId], references: [id])
  bookings Booking[]

  @@map("rooms")
}

model Booking {
  id        String        @id @default(uuid())
  studentId String        @map("student_id")
  roomId    String        @map("room_id")
  status    BookingStatus
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  student  Student   @relation(fields: [studentId], references: [id])
  room     Room      @relation(fields: [roomId], references: [id])
  payments Payment[]

  @@map("bookings")
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @map("booking_id")
  studentId     String        @map("student_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentType   PaymentType   @map("payment_type")
  paymentMethod PaymentMethod @map("payment_method")
  status        PaymentStatus
  createdAt     DateTime      @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("payments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
